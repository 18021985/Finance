# Alpha Vantage API Key (Free tier: 25 requests/day, 5 requests/minute)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# NewsAPI Key (Free tier: 100 requests/day)
# Get free key at: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Frontend Configuration (for Netlify deployment)
# Set this to your Render backend URL in Netlify environment variables
# Example: https://your-app-name.onrender.com
NEXT_PUBLIC_API_URL=https://your-render-app.onrender.com
